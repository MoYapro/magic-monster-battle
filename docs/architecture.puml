@startuml Wand Magic - System Overview

skinparam packageStyle rectangle
skinparam shadowing false

package "Battle" {

  class BattleScene {
    +_ready()
    --
    -_fire_at_cell(cell: Vector2i)
    -_start_targeting(wand: WandDisplay)
    -_cancel_targeting()
    -_update_hover(mouse: Vector2)
  }

  class EnemyGrid {
    +COLS: int = 3
    +ROWS: int = 5
    --
    +place_enemy(enemy, pos): bool
    +remove_enemy(id)
    +get_enemy_at(pos): EnemyData
    +apply_damage(cell, amount)
    +get_hit_cells(target, pattern): Array
    +can_place_enemy(pos, size): bool
    ..static..
    +get_cells_for_enemy(pos, size): Array
    +is_within_bounds(pos, size): bool
  }

  class EnemyData {
    +id: String
    +display_name: String
    +max_hp: int
    +current_hp: int
    +grid_size: Vector2i
    +color: Color
  }

  class MageDisplay {
    +setup(mage: MageData, height: float)
    +set_highlighted(on: bool)
    +set_hovered(on: bool)
    +get_rect(): Rect2
  }

  class MageData {
    +name: String
    +max_hp: int
    +current_hp: int
  }

  class ManaDisplay {
    +WIDTH: float
    +setup(current, max, height)
  }

  class TurnManager <<planned>> {
    +start_round()
    +end_player_turn()
    +resolve_enemy_actions()
  }

  class ManaPool <<planned>> {
    +current: int
    +max: int
    +replenish_per_turn()
    +spend(amount): bool
  }

}

package "Wand System" {

  class WandDisplay {
    +setup(wand: WandData)
    +get_wand_data(): WandData
    +get_tip_spell(): SpellData
    +get_display_size(): Vector2
    +set_highlighted(on: bool)
    +set_hovered(on: bool)
    --
    signal tip_pressed(wand)
  }

  class WandData {
    +slots: Array[SpellSlotData]
    --
    +get_tip_slot(): SpellSlotData
    +get_slot(id): SpellSlotData
    +get_total_damage(): int
  }

  class SpellSlotData {
    +id: String
    +grid_col: int
    +grid_row: int
    +next_id: String
    +is_tip: bool
    +spell: SpellData
  }

  class SpellData {
    +display_name: String
    +abbreviation: String
    +tags: Array[String]
    +element_color: Color
    +hit_pattern: Array[Vector2i]
    +icon: String
    +damage: int
  }

  class WandGenerator {
    ..static..
    +generate(rng): WandData
  }

  class SpellInteraction <<planned>> {
    +tags_a: Array[String]
    +tags_b: Array[String]
    +interaction_type: String
  }

}

package "Progression" <<planned>> {

  class LootScreen <<planned>>
  class LevelUpScreen <<planned>>
  class PathSelection <<planned>>
  class Biome <<planned>> {
    +monster_roster: Array
    +loot_table: Array
    +battle_count: int
  }

}

BattleScene --> EnemyGrid
BattleScene "1" *-- "3" WandDisplay
BattleScene "1" *-- "3" MageDisplay
BattleScene "1" *-- "1" ManaDisplay
BattleScene --> TurnManager

EnemyGrid "1" *-- "0..*" EnemyData
MageDisplay --> MageData

WandDisplay --> WandData
WandData "1" *-- "2..10" SpellSlotData
SpellSlotData --> SpellData
WandGenerator ..> WandData : creates
SpellData --> SpellInteraction

@enduml
